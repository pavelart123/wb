{
  "version": 2,
  "builds": [
    {
      "src": "dist/**/browser/**",
      "use": "@vercel/static"
    },
    {
      "src": "dist/**/server/**/*.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "dist/server/server.mjs"
    }
  ],
  "functions": {
    "dist/server/server.mjs": {
      "includeFiles": "dist/**"
    }
  }
}