{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/1/search/:query?page=:page",
      "destination": "https://search.wb.ru/exactmatch/ru/common/v18/search?appType=1&curr=rub&dest=-1257786&lang=ru&page=:page&query=:query&resultset=catalog&sort=popular&spp=30&suppressSpellcheck=false"
    },
    {
      "source": "/api/1/search/:path*",
      "destination": "https://search.wb.ru/exactmatch/ru/common/v18/search/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://u-search.wb.ru/exactmatch/ru/common/v18/search/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
